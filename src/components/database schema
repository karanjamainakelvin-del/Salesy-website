// prisma/schema.prisma
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String
  propertyType String // e.g., "Apartments in Kilimani"
  budget    String
  status    String   @default("NEW") // NEW, CONTACTED, CLOSED
  createdAt DateTime @default(now())
}

model Admin {
  id       String @id @default(cuid())
  email    String @unique
  password String
}
